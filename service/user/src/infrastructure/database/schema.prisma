generator client {
    provider = "prisma-client-js"
    output   = "./generated/prisma"
}

datasource db {
    provider = "postgresql"
}

model User {
    id String @default(uuid()) @unique
    username String
    email String @unique
    roles String
    password String
    image String
}

model user_audit {
    id String @default(uuid()) @unique
    ip_addres String
    device_type String
    id_user String
    roles String
    failed Boolean
    action String
    failed_message String
    user User @relation(fields: [id_user] , references: [id])
}