generator client {
    provider = "prisma-client-js"
    output   = "./generated/prisma"
}

datasource db {
    provider = "postgresql"
}

model User {
    id                String              @unique @default(uuid())
    username          String
    email             String              @unique
    roles             String
    password          String
    image             String
    verify            Boolean
    verify_at         DateTime?
    refreshTokens     refresh_token[]
    userAudits        user_audit[]
    codeVerifications code_verification[]
}

model refresh_token {
    id         String   @unique @default(uuid())
    user_id    String
    expired    DateTime @default(now())
    created_at DateTime @default(now())
    user       User     @relation(fields: [user_id], references: [id])
}

model user_audit {
    id             String  @unique @default(uuid())
    ip_addres      String
    device_type    String
    user_id        String
    roles          String
    failed         Boolean
    action         String
    failed_message String
    user           User    @relation(fields: [user_id], references: [id])
}

model code_verification {
    id         String   @unique @default(uuid())
    user_id    String
    code       String
    status     String
    created_at DateTime @default(now())
    expired    DateTime @default(now())
    user       User     @relation(fields: [user_id], references: [id])
}
