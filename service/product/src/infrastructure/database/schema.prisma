generator client {
    provider = "prisma-client-js"
    output   = "./generated/prisma"
}

datasource db {
    provider = "postgresql"
}

model Category {
    id        String               @id @default(uuid())
    name      String               @unique
    slug      String               @unique
    products  CategoryOnProducts[]
    createdAt DateTime             @default(now())
}

model Product {
    id         String               @id @default(uuid())
    storeId    String
    categoryId String
    category   CategoryOnProducts[]

    name        String
    slug        String @unique
    description String @db.Text
    price       Int
    stock       Int    @default(0)

    mainImage String?
    images    Json?

    isActive Boolean @default(true)
    version  Int     @default(0)

    auditLogs ProductAuditLog[]

    createdAt DateTime @default(now())
    updatedAt DateTime @updatedAt

    @@index([storeId])
    @@index([categoryId])
}

model CategoryOnProducts {
    categoryId String
    product    Product  @relation(fields: [ProductId], references: [id])
    ProductId  String
    category   Category @relation(fields: [categoryId], references: [id])

    @@id([categoryId, ProductId])
}

model ProductAuditLog {
    id        String  @id @default(uuid())
    productId String
    product   Product @relation(fields: [productId], references: [id])

    action    String
    oldValue  Json?
    newValue  Json?
    changedBy String

    createdAt DateTime @default(now())

    @@map("product_audit_logs")
}
